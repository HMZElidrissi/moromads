{
  "name": "moromads",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "wrangler d1 execute moromads --local --file=db/schema.sql 2>/dev/null && wrangler d1 execute moromads --local --file=db/seed.sql 2>/dev/null; react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@cloudflare/vite-plugin": "^1.42.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/cloudflare": "8.0.1",
    "@react-router/dev": "8.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-rough-notation": "^1.0.8",
    "react-router": "8.0.1",
    "shadcn": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^4.103.0"
  },
  "packageManager": "pnpm@11.5.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
